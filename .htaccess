# Apache config for OVH Web Hosting
# Static site: HTML/CSS/JS/JPG only — no PHP processing needed.

# ---------- Force HTTPS ----------
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ---------- Force non-www → apex (machines-for-sale.pk) ----------
RewriteCond %{HTTP_HOST} ^www\.machines-for-sale\.pk$ [NC]
RewriteRule ^(.*)$ https://machines-for-sale.pk/$1 [R=301,L]

# ---------- Default document ----------
DirectoryIndex index.html urdu.html

# ---------- Custom 404 ----------
ErrorDocument 404 /404.html

# ---------- Compression (gzip) ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------- Cache headers (browser caching) ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 hour"
  # Images: 6 months (machines rarely change)
  ExpiresByType image/jpeg                    "access plus 6 months"
  ExpiresByType image/png                     "access plus 6 months"
  ExpiresByType image/webp                    "access plus 6 months"
  ExpiresByType image/svg+xml                 "access plus 6 months"
  ExpiresByType image/x-icon                  "access plus 6 months"
  # CSS / JS: 1 month
  ExpiresByType text/css                      "access plus 1 month"
  ExpiresByType application/javascript        "access plus 1 month"
  # Fonts
  ExpiresByType font/woff2                    "access plus 6 months"
  ExpiresByType font/woff                     "access plus 6 months"
  # HTML / XML / JSON: short cache
  ExpiresByType text/html                     "access plus 1 hour"
  ExpiresByType application/json              "access plus 1 hour"
  ExpiresByType application/xml               "access plus 1 hour"
</IfModule>

# ---------- Security headers ----------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  # Long cache for static assets
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|css|js)$">
    Header set Cache-Control "public, max-age=15552000, immutable"
  </FilesMatch>
</IfModule>

# ---------- MIME types ----------
AddType application/xml             .xml
AddType application/json            .json
AddType text/plain                  .txt
AddType image/svg+xml               .svg

# ---------- Prevent directory listing ----------
Options -Indexes

# ---------- Block access to sensitive files ----------
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<Files ".htaccess">
  Require all denied
</Files>
